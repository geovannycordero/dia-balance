# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

########################################
# Dependencies & Package Managers
########################################

# Node dependencies
/node_modules/

# Yarn / pnpm Plug'n'Play
/.pnp
.pnp.*
.pnp.js

# Yarn v2+ metadata (kept if using zero‑install; adjust as needed)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Legacy/alt dependency dirs
jspm_packages/
bower_components/
web_modules/

########################################
# Build Output & Caches
########################################

# Next.js
/.next/
/out/

# General build output
/build/
/dist/
build/Release

# Coverage
/coverage
coverage
*.lcov
.nyc_output

# Parcel / generic caches
.cache
.parcel-cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ESLint cache
.eslintcache

# Optional npm cache directory
.npm

########################################
# Logs & Diagnostics
########################################

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

########################################
# Environment & Secrets
########################################

# Never commit secrets; opt-in explicitly if needed
.env
.env.local
.env.test
.env.production
.env*.local

########################################
# Framework / Tooling Artifacts
########################################

# Vercel
.vercel

# Nuxt / Vue / Gatsby (harmless if unused)
.nuxt
dist
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.tern-port
.vscode-test

########################################
# TypeScript
########################################

*.tsbuildinfo
next-env.d.ts

########################################
# Editors & OS
########################################

# macOS
.DS_Store
*.DS_STORE

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code / JetBrains
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

########################################
# Playwright
########################################

/test-results/
/playwright-report/
e2e/.auth/

########################################
# Miscellaneous
########################################

# REPL history
.node_repl_history

# Output of `npm pack`
*.tgz

# PID files
pids
*.pid
*.pid.lock
*.seed

# GraphQL tooling
graphql_schema.json
.graphql_cache
.graphql_ppx_cache

# ReScript
.merlin
/lib
*.bs.js
.bsb.lock

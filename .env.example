# ============================================
# Dia Balance - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env files to version control

# ============================================
# Application
# ============================================
# Application name (used in email templates)
APP_NAME=Dia Balance

# Node environment (development, production, test)
NODE_ENV=development

# ============================================
# Database
# ============================================
# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?[params]
# Local example: postgresql://dia-balance_user:dia-balance_password@localhost:5432/dia-balance_db
# Production: Use your production database URL
DATABASE_URL=postgresql://dia-balance_user:dia-balance_password@localhost:5432/dia-balance_db

# ============================================
# NextAuth.js
# ============================================
# Secret key for encrypting JWT tokens and sessions
# Generate a random string: openssl rand -base64 32
# REQUIRED for production
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# Base URL of your application
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Enable NextAuth debug mode (optional, for troubleshooting)
# Set to 'true' to enable debug logs
NEXTAUTH_DEBUG=false

# ============================================
# Email Configuration
# ============================================
# Email address to send verification emails from
# This should be a verified domain in production
EMAIL_FROM=noreply@example.com

# ============================================
# Email Provider (Production Only)
# ============================================
# Resend API key for sending emails in production
# Get your API key from https://resend.com/api-keys
# Only needed in production (NODE_ENV=production)
# Leave empty for local development (emails will be logged to console)
RESEND_API_KEY=

# ============================================
# Docker/PostgreSQL (Optional - for local development)
# ============================================
# These are used by docker-compose.yml if running PostgreSQL via Docker
# Defaults are provided, but you can override them
POSTGRES_DB=dia-balance_db
POSTGRES_USER=dia-balance_user
POSTGRES_PASSWORD=dia-balance_password
POSTGRES_PORT=5432

# ============================================
# Notes
# ============================================
# - In development, emails are logged to console instead of being sent
# - In production, you MUST set:
#   - NEXTAUTH_SECRET (generate a secure random string)
#   - NEXTAUTH_URL (your production domain)
#   - RESEND_API_KEY (for email sending)
#   - EMAIL_FROM (verified email domain)
#   - DATABASE_URL (production database connection string)
# - Never commit .env files to version control
# - Use different secrets for development and production
